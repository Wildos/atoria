{{#unless is_private}}
<div class="atoria dice dos-dice flexcol
{{#if is_success}}success{{else}}failure{{/if}}
{{#if (or is_critical_success is_critical_failure)}}critical{{/if}}
">
    <h5 {{#if owner_or_gm}}data-tooltip-class="atoria-tooltip" data-tooltip="{{{descriptive_tooltip}}}"{{/if}}>{{localize title}}{{#if owner_or_gm}}: {{success_value}}{{/if}}</h5>
    <label class="alteration-label">
        {{#if adv_disadv}}
        <span>{{adv_disadv}}</span>
        {{/if}}
        {{#if luck_applied}}
        <span>{{localize "ATORIA.Ruleset.Luck"}}: {{luck_applied}}</span>
        {{/if}}
        {{#if dos_mod}}
        <span>{{localize "ATORIA.Chat_message.Dice.Dos"}}: {{dos_mod}}</span>
        {{/if}}
        {{#if is_danger}}
        <span>{{localize "ATORIA.Chat_message.Dice.Is_Danger"}}</span>
        {{/if}}
    </label>
    {{#if (or adv_disadv luck_applied dos_mod is_danger)}}
        <hr/>
    {{/if}}
    <div class="flexrow">
        <label class="title" data-tooltip='{{{dice_tooltip}}}'>
        {{#if is_success}}
            {{#if is_critical_success}}
                {{localize "ATORIA.Chat_message.Dice.Critical_success"}}
            {{else}}
                {{localize "ATORIA.Chat_message.Dice.Success"}}
            {{/if}}
        {{else}}
            {{#if is_critical_failure}}
                {{localize "ATORIA.Chat_message.Dice.Critical_failure"}}
            {{else}}
                {{localize "ATORIA.Chat_message.Dice.Failure"}}
            {{/if}}
        {{/if}}
        : {{dice_value}}</label>

        <label class="result-degree" data-tooltip='{{{dice_tooltip}}}'>DR: {{degree_of_success}} ({{margin_of_success}})</label>
    </div>
</div>
{{/unless}}
