<section class='atoria tooltip flexcol'>
    <h5>{{item.name}}{{>"atoria.v2.tooltips_partials.time-limitation-tooltip" limitation=item.system.limitation}}</h5>
    {{>"atoria.v2.tooltips_partials.cost-tooltip" cost=item.system.cost systemFields=systemFields.cost.fields}}

    {{#if item.system.restriction}}
    <p>{{localize systemFields.restriction.label}}: {{brNewLines item.system.restriction}}</p>
    {{/if}}
    {{#if item.system.effect}}
    <p>{{localize systemFields.effect.label}}: {{brNewLines item.system.effect}}</p>
    {{/if}}
    {{#if item.system.critical_effect}}
    <p>{{localize systemFields.critical_effect.label}}: {{brNewLines item.system.critical_effect}}</p>
    {{/if}}
</section>
